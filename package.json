{
  "name": "mailcenter-backend",
  "version": "1.0.0",
  "description": "MailCenter - Multi-account email management backend",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:worker": "nodemon src/worker.ts",
    "build": "tsc --skipLibCheck && node copy-sql.js",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "migrate": "ts-node src/database/runMigrations.ts",
    "migrate:prod": "node dist/database/runMigrations.js",
    "db:push": "ts-node src/database/runMigrations.ts",
    "railway:migrate": "node dist/database/runMigrations.js && node dist/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "@aws-sdk/s3-request-presigner": "^3.1034.0",
    "@azure/msal-node": "^5.1.4",
    "@sentry/node": "^10.49.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.76.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.0.156",
    "ioredis": "^5.10.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
